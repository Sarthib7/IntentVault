# Copy to `.env.local` at this repo root (recommended). Next.js in `apps/web` loads it via next.config.
# On Vercel: set the same variables in Project Settings → Environment Variables.

# Public signals: mock | auto (DexScreener with mock fallback)
INTENTVAULT_SIGNALS_MODE=auto

# Inference: mock | auto (SolRouter when SOLROUTER_API_KEY is set, else mock)
INTENTVAULT_INFERENCE_MODE=auto

# Required for live SolRouter (@solrouter/sdk encrypted inference)
SOLROUTER_API_KEY=sk_solrouter_your_key_here

# Optional: gpt-oss-20b | gemini-flash | claude-sonnet | claude-sonnet-4 | gpt-4o-mini
SOLROUTER_MODEL=gpt-oss-20b

# Optional override for SolRouter API base URL
SOLROUTER_BASE_URL=https://api.solrouter.com/agent
