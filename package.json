{
  "name": "intentvault",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @intentvault/web",
    "build": "npm run build --workspace @intentvault/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run --config vitest.config.ts"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
